{
  "version": 2,
  "buildCommand": "npm run build",
  "functions": {
    "dist/portfolio-photographe/server/server.mjs": {
      "runtime": "nodejs20.x"
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "https://portfolio-app-backend-57tj.onrender.com/api/$1"
    },
    {
      "src": "/(.*\\.js|.*\\.css|.*\\.woff2?|.*\\.png|.*\\.jpg|.*\\.jpeg|.*\\.svg|.*\\.ico|.*\\.webp)",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      },
      "dest": "/dist/portfolio-photographe/browser/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/dist/portfolio-photographe/server/server.mjs"
    }
  ]
}
