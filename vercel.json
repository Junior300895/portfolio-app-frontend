{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://portfolio-app-backend-57tj.onrender.com/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/:path*\\.(js|css|woff|woff2|png|jpg|jpeg|svg|ico|webp)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
